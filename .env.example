# Copy to .env and fill in. .env is gitignored.

# --- Data ---
# Databento API key (https://databento.com) — historical OPRA, $125 free credit on signup.
DATABENTO_API_KEY=

# --- LLM (via LiteLLM) ---
# Set the key for whichever provider you use. Model is selected via OPTIONPILOT_MODEL.
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=

# Default model (LiteLLM model string). Examples:
#   deepseek/deepseek-chat
#   anthropic/claude-opus-4-8
#   openai/gpt-4o
#   xai/grok-2
OPTIONPILOT_MODEL=deepseek/deepseek-chat

# --- Cost guard ---
# Abort a Databento fetch if its estimated cost exceeds this many USD (protects the $125 credit).
OPTIONPILOT_MAX_FETCH_USD=5.0

# --- Paths ---
OPTIONPILOT_CACHE_DIR=./data_cache
OPTIONPILOT_RUNS_DIR=./runs
