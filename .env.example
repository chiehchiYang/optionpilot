# Copy to .env and fill in. .env is gitignored.

# --- Data ---
# Which option data source to use: "databento" (per-GB, any ticker) or "thetadata"
# (free local terminal, EOD + bid/ask + volume; see docs/thetadata_setup.md).
OPTIONPILOT_DATA_SOURCE=databento

# Databento API key (https://databento.com) — historical OPRA, $125 free credit on signup.
DATABENTO_API_KEY=

# ThetaData free tier — local Theta Terminal v3 endpoint (only used when DATA_SOURCE=thetadata).
OPTIONPILOT_THETADATA_URL=http://127.0.0.1:25503

# --- LLM (via LiteLLM) ---
# Set the key for whichever provider you use. Model is selected via OPTIONPILOT_MODEL.
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=

# Default model (LiteLLM model string). Examples:
#   deepseek/deepseek-v4-flash   (deepseek-chat retires 2026-07-24)
#   deepseek/deepseek-v4-pro
#   anthropic/claude-opus-4-8
#   openai/gpt-4o
#   xai/grok-2
OPTIONPILOT_MODEL=deepseek/deepseek-v4-flash

# --- Local model (optional) ---
# Point at a local OpenAI-compatible server (vLLM / Ollama / LM Studio) for zero-cost dev.
# Example with vLLM serving Qwen3-Coder-30B:
#   OPTIONPILOT_MODEL=hosted_vllm/Qwen/Qwen3-Coder-30B-A3B-Instruct
#   OPTIONPILOT_API_BASE=http://localhost:8000/v1
#   OPTIONPILOT_API_KEY=local
OPTIONPILOT_API_BASE=
OPTIONPILOT_API_KEY=

# --- Cost guard ---
# Abort a Databento fetch if its estimated cost exceeds this many USD (protects the $125 credit).
OPTIONPILOT_MAX_FETCH_USD=5.0

# --- Paths ---
OPTIONPILOT_CACHE_DIR=./data_cache
OPTIONPILOT_RUNS_DIR=./runs
